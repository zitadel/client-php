{
    "name": "zitadel/client",
    "description": "The Zitadel SDK is a convenience wrapper around the Zitadel APIs to assist you in integrating with your Zitadel environment. This SDK enables you to handle resources, settings, and configurations within the Zitadel platform.",
    "license": "MIT",
    "version": "1.0.0",
    "require": {
        "php": "^8.5",
        "ext-curl": "*",
        "ext-json": "*",
        "ext-mbstring": "*",
        "symfony/http-client": "^6.0|^7.0",
        "symfony/mime": "^6.0|^7.0",
        "symfony/serializer": "^6.0|^7.0",
        "symfony/property-access": "^6.0|^7.0",
        "symfony/property-info": "^6.0|^7.0",
        "symfony/uid": "^6.0|^7.0",
        "phpdocumentor/reflection-docblock": "^5.3",
        "php-ds/php-ds": "^1.5",
        "ext-openssl": "*",
        "league/uri": "^7.5",
        "firebase/php-jwt": "^7.0.0"
    },
    "require-dev": {
        "pestphp/pest": "^4.0",
        "friendsofphp/php-cs-fixer": "^3.95",
        "phpstan/phpstan": "^2.1",
        "squizlabs/php_codesniffer": "^3.13",
        "slevomat/coding-standard": "^8.16",
        "dealerdirect/phpcodesniffer-composer-installer": "^1.0",
        "rector/rector": "^2.4",
        "ext-dom": "*",
        "haydenpierce/class-finder": "^0.5.3",
        "testcontainers/testcontainers": "^1.0",
        "vlucas/phpdotenv": "^5.6",
        "mridang/phpunit-reporters": "^1.0",
        "icanhazstring/composer-unused": "^0.9.3"
    },
    "scripts": {
        "test": "pest --testsuite unit,tests --coverage --coverage-clover=build/coverage/clover.xml --log-junit=build/reports/junit.xml",
        "phpstan": "phpstan analyse --memory-limit=-1",
        "rector": "rector process",
        "format": "php-cs-fixer fix",
        "depcheck": "composer-unused"
    },
    "config": {
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true,
            "pestphp/pest-plugin": true
        }
    },
    "suggest": {
        "ext-brotli": "For brotli response decompression",
        "ext-zstd": "For zstd response decompression",
        "ext-ds": "Use the PECL ext-ds for native performance",
        "open-telemetry/api": "For automatic W3C Trace Context (traceparent) propagation on API calls"
    },
    "autoload": {
        "psr-4": {
            "Zitadel\\Client\\": "lib/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Zitadel\\Client\\Test\\": "test/",
            "Zitadel\\Client\\Spec\\": "spec/"
        }
    }
}
