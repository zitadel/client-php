parameters:
  level: 9
  tmpDir: .phpstan
  paths:
    - .
  excludePaths:
    - vendor
    # Pest test files use magic methods (test(), expect(), beforeEach(),
    # etc.) that phpstan cannot analyse without the dedicated
    # pestphp/pest-plugin-phpstan plugin. Skip the tests directory until
    # that plugin is wired up.
    - tests
