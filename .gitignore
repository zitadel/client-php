# Composer dependencies
/vendor/

# Composer lock file
composer.lock

# PHPUnit cache
.phpunit.cache/
.phpunit.result.cache

# Tool caches
.phpcsf
.phpstan/

# Generator metadata (regenerated on every `make generate`)
.openapi-generator/

# Coverage output
.out/

# Local secrets / test credentials (never commit)
.env

# Local Claude Code state (never commit)
.claude/worktrees/
.claude/settings.local.json
